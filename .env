# Copy to ".env" and fill values.
# Used by docker-compose (Topic 12.1/12.2)

DEBUG=1
SECRET_KEY=dev-docker-secret-key
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
PUBLIC_BASE_URL=http://127.0.0.1:8000

POSTGRES_DB=ngo_management
POSTGRES_USER=ngo_user
POSTGRES_PASSWORD=ngo_pass
POSTGRES_PORT=5432

DATABASE_URL=postgres://ngo_user:ngo_pass@db:5432/ngo_management
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

PORT=8000

